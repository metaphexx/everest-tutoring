# Database. SQLite for local dev; Postgres for production (see DEV_NOTES.md for
# the provider + adapter switch). lib/db.ts picks the adapter from the URL scheme.
DATABASE_URL="file:./dev.db"

# Error monitoring (optional). Set to forward exceptions to Sentry; see lib/log.ts.
# SENTRY_DSN="https://...@...ingest.sentry.io/..."

# NextAuth - session secret. AUTH_SECRET is the current name; NEXTAUTH_SECRET is
# the legacy alias (set both to the same value). Generate: openssl rand -base64 32
AUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Protects the /api/cron/* endpoints. When set, callers must send
# `Authorization: Bearer <CRON_SECRET>`. Used by the nightly batch + reminders.
CRON_SECRET="generate-with: openssl rand -base64 32"

# Semantic search embeddings (Voyage AI). Without a key, search uses a local
# hash embedding (works offline, lexical only). https://www.voyageai.com
VOYAGE_API_KEY=""
VOYAGE_MODEL="voyage-3-lite"

# Inbound email replies POST to /api/webhooks/email with this shared secret.
INBOUND_EMAIL_SECRET=""

# Safeguarding: when set, Escalate in the moderation queue emails this address a
# real incident alert (on top of opening an Incident + in-CRM notification).
SAFEGUARDING_LEAD_EMAIL=""

# Per-task monthly AI spend caps in cents (optional). Over budget -> the feature
# falls back to its deterministic path. AI_BUDGET_CENTS is the global cap; or set
# AI_BUDGET_<TASK>_CENTS (COPILOT/MODERATION/SUMMARY/REPORT/ANALYTICS/SUPPORT/DRAFT).
# AI_BUDGET_CENTS="5000"
# AI_BUDGET_COPILOT_CENTS="2000"

# Stripe - get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Resend - get from https://resend.com/api-keys
RESEND_API_KEY="re_..."

# Twilio - get from https://console.twilio.com
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+61..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Canonical public origin - used for SEO (metadataBase, sitemap, robots) and as
# the event_source_url on server-side Meta events. No trailing slash.
NEXT_PUBLIC_SITE_URL="https://everesttutoring.com.au"
ADMIN_EMAIL="admin@everesttutoring.com.au"
FROM_EMAIL="bookings@everesttutoring.com.au"
FROM_NAME="Everest Tutoring"

# Meta (Facebook) ads tracking. Leave all unset to disable tracking entirely
# (the pixel renders nothing and the Conversions API no-ops).
#   - Pixel/Dataset ID from Events Manager (the browser pixel + CAPI share this).
#   - CAPI access token: Events Manager -> Settings -> Conversions API -> generate.
#   - Test code (optional): Events Manager -> Test Events, to verify server events.
NEXT_PUBLIC_FB_PIXEL_ID="..."
META_CAPI_ACCESS_TOKEN="..."
# META_CAPI_TEST_EVENT_CODE="TEST12345"

# AI (Claude) - get a key from https://console.anthropic.com
# Leave unset to run all AI features in safe stub mode.
ANTHROPIC_API_KEY="sk-ant-..."
# Models are plug-and-play: swapping them never changes any prompt.
# Out of the box each task uses a COST-OPTIMIZED default (cheap+fast models for
# high-volume work, stronger models for reasoning):
#   moderation, summary -> haiku   |   support, analytics, report -> sonnet
#   copilot (Elliot)    -> opus
# To force ONE model everywhere, uncomment AI_MODEL. To tune a single task, set
# its AI_MODEL_<TASK> override.
# AI_MODEL="claude-opus-4-8"
# AI_MODEL_MODERATION="claude-haiku-4-5"
# AI_MODEL_SUMMARY="claude-haiku-4-5"
# AI_MODEL_SUPPORT="claude-sonnet-4-6"
# AI_MODEL_ANALYTICS="claude-sonnet-4-6"
# AI_MODEL_REPORT="claude-sonnet-4-6"
# AI_MODEL_COPILOT="claude-opus-4-8"

# Xero accounting - create a Custom Connection (client credentials) at
# https://developer.xero.com/app/manage and grant the accounting.transactions
# + accounting.contacts scopes. Leave unset to run invoicing in safe preview
# mode (invoices are composed and logged, but nothing is pushed to Xero).
XERO_CLIENT_ID="..."
XERO_CLIENT_SECRET="..."
# Account codes from your Xero chart of accounts:
XERO_SALES_ACCOUNT_CODE="200"      # revenue account for tutoring income
XERO_CLEARING_ACCOUNT_CODE="090"   # bank/clearing account Stripe payouts land in
# GST/tax - defaults produce a NO-GST invoice. If registered for GST, set
# XERO_TAX_TYPE="OUTPUT" and XERO_LINE_AMOUNT_TYPE="Inclusive".
XERO_TAX_TYPE="NONE"
XERO_LINE_AMOUNT_TYPE="NoTax"

# Google Drive (booklets / materials the AI suggests for tutors to print).
# Service account with read access to the booklets folder. See DEV_NOTES.md.
# Leave unset to run material suggestions in scaffold mode.
GOOGLE_DRIVE_CLIENT_EMAIL="...@...iam.gserviceaccount.com"
GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_BOOKLETS_FOLDER_ID="..."
